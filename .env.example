# ─── LLM backends (set at least one) ─────────────────────────────────────────
ASI1_API_KEY=your_asi1_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── uAgents — Agentverse registration ───────────────────────────────────────
AGENTVERSE_KEY=your_agentverse_key_here

# ─── uAgent wallet seeds ─────────────────────────────────────────────────────
OPERATOR_SEED=operator-dev-seed
PRIORITY_SEED=priority-handler-dev-seed
CASE_SEED=case-handler-dev-seed

# ─── Agent ports ─────────────────────────────────────────────────────────────
OPERATOR_PORT=8001
PRIORITY_PORT=8002
CASE_PORT=8003

# ─── Flask backend ────────────────────────────────────────────────────────────
BACKEND_PORT=8001
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Database paths (relative to repo root) ───────────────────────────────────
CLINICIANS_DB=db/clinicians.json
EHR_DB=db/ehr_records.json
SCHEDULE_DB=db/clinician_schedules.json
AUTONOMY_CONFIG=config/autonomy_config.json

# ─── Backend URL (used by agents to call the Flask REST API) ──────────────────
BACKEND_URL=http://127.0.0.1:8001
